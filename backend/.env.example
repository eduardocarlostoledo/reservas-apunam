# Database (use DATABASE_URL for Railway, or individual vars for local)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apunam
DB_USER=postgres
DB_PASSWORD=your_password

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=secret

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Resend API
EMAIL_FROM=noreply@apunam.org.ar
RESEND_API_KEY=re_your_api_key_here


# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173


